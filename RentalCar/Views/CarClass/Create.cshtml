@model RentalCar.Application.Models.CarClass

@{
    ViewData["Title"] = "Create";
    ViewData["Header"] = "クラス登録";
}

<section class="max-w-2xl">
    <form asp-action="Create">
        <div class="shadow border border-primary rounded p-6">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input asp-for="CreatedAt" type="hidden" />
            <input asp-for="UpdatedAt" type="hidden" />
            <div>
                <label asp-for="Name" class="block font-medium text-sm"></label>
                <div class="mt-1">
                    <input asp-for="Name" type="text" class="w-full px-4 py-2 border rounded-md dark:bg-darker dark:border-gray-700 focus:outline-none focus:ring focus:ring-primary-100 dark:focus:ring-primary-darker" />
                </div>
                <div class="mt-1 text-red-500 text-sm">
                    @Html.ValidationMessageFor(m => m.Name)
                </div>
            </div>
            <div>
                <label asp-for="CarCategoryId" class="block font-medium text-sm"></label>
                <div class="mt-1">
                    <select asp-for="CarCategoryId" class="px-4 py-2 border rounded-md dark:bg-darker dark:border-gray-700 focus:outline-none focus:ring focus:ring-primary-100 dark:focus:ring-primary-darker" asp-items="ViewBag.CarCategoryId"></select>
                </div>
                <div class="mt-1 text-red-500 text-sm">
                    @Html.ValidationMessageFor(m => m.CarCategoryId)
                </div>
            </div>
            <div>
                <label asp-for="Description" class="block font-medium text-sm"></label>
                <div class="mt-1">
                    <textarea asp-for="Description" class="w-full px-4 py-2 border rounded-md dark:bg-darker dark:border-gray-700 focus:outline-none focus:ring focus:ring-primary-100 dark:focus:ring-primary-darker"></textarea>
                </div>
                <div class="mt-1 text-red-500 text-sm">
                    @Html.ValidationMessageFor(m => m.Description)
                </div>
            </div>
            <div>
                <label asp-for="Remarks" class="block font-medium text-sm"></label>
                <div class="mt-1">
                    <textarea asp-for="Remarks" class="w-full px-4 py-2 border rounded-md dark:bg-darker dark:border-gray-700 focus:outline-none focus:ring focus:ring-primary-100 dark:focus:ring-primary-darker"></textarea>
                </div>
                <div class="mt-1 text-red-500 text-sm">
                    @Html.ValidationMessageFor(m => m.Remarks)
                </div>
            </div>
            <div>
                <label asp-for="DisplayOrder" class="block font-medium text-sm"></label>
                <div class="mt-1">
                    <input asp-for="DisplayOrder" type="number" class="w-full px-4 py-2 border rounded-md dark:bg-darker dark:border-gray-700 focus:outline-none focus:ring focus:ring-primary-100 dark:focus:ring-primary-darker" />
                </div>
                <div class="mt-1 text-red-500 text-sm">
                    @Html.ValidationMessageFor(m => m.DisplayOrder)
                </div>
            </div>
        </div>
        <div class="flex justify-between mt-4">
            <a asp-action="Index" class="px-4 py-2 text-sm text-white rounded-md bg-gray-400 hover:bg-gray-500 focus:outline-none focus:ring focus:ring-primary-dark focus:ring-offset-1 focus:ring-offset-white dark:focus:ring-offset-dark">一覧へ戻る</a>
            <a asp-action="Delete" asp-route-id="@Model?.Id" class="px-4 py-2 text-sm text-white rounded-md bg-orange-400 hover:bg-orange-500 focus:outline-none focus:ring focus:ring-primary-dark focus:ring-offset-1 focus:ring-offset-white dark:focus:ring-offset-dark">削除する</a>
            <input type="submit" value="登録する" class="px-4 py-2 text-sm text-white rounded-md bg-primary hover:bg-primary-dark focus:outline-none focus:ring focus:ring-primary-dark focus:ring-offset-1 focus:ring-offset-white dark:focus:ring-offset-dark" />
        </div>
    </form>
</section>


