@model ProfileInfoEditor

<form asp-action="Update" asp-controller="Profile" method="post" class="max-w-2xl flex flex-col space-y-6">
    <div class="mt-6">
        <label asp-for="Name" class="block font-medium text-sm text-gray-700"></label>
        <div class="mt-1">
            <input asp-for="Name" type="text" required class="w-full px-4 py-2 border rounded-md dark:bg-darker dark:border-gray-700 focus:outline-none focus:ring focus:ring-primary-100 dark:focus:ring-primary-darker w-full" />
        </div>
        <div class="mt-1 text-red-500 text-sm">
            @Html.ValidationMessageFor(m => m.Name)
        </div>
    </div>
    <div>
        <label asp-for="Email" class="block font-medium text-sm text-gray-700"></label>
        <div class="mt-1">
            <input asp-for="Email" required type="email" class="w-full px-4 py-2 border rounded-md dark:bg-darker dark:border-gray-700 focus:outline-none focus:ring focus:ring-primary-100 dark:focus:ring-primary-darker w-full" />
        </div>
        <div class="mt-1 text-red-500 text-sm">
            @Html.ValidationMessageFor(m => m.Email)
        </div>
    </div>
    <div>
        <button type="submit" class="text-left px-4 py-2 bg-indigo-700 hover:bg-indigo-800 rounded-md font-semibold text-xs text-white uppercase tracking-widest focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 transition">
            保存
        </button>
    </div>
</form>
