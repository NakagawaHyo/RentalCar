@model ProfileEditor
@{
    ViewData["Title"] = "Edit Profile";
    ViewData["Header"] = "プロフィール";
}

<section class="max-w-6xl px-6">
    <article class="bg-white shadow rounded-lg w-full my-6 p-6">
        <h2 class="text-xl font-medium mb-2">
            プロフィール情報    
        </h2>
        <p class="text-gray-600">
            アカウントのプロフィール情報を更新します。
        </p>
        @{
            await Html.RenderPartialAsync("_ProfileInformationEditor", Model.ProfileInfoEditor); 
        }
    </article>
    <article class="bg-white shadow rounded-lg w-full my-6 p-6">
        <h2 class="text-xl font-medium mb-2">
            パスワードの更新
        </h2>
        <p class="text-gray-600">
            アカウントのパスワードを更新します。
        </p>
        @{
            await Html.RenderPartialAsync("_ProfilePasswordEditor", Model.ProfilePasswordEditor);
        }
    </article>
</section>
