@model Register
@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Register";
}
<div class="sm:py-12">
    <section class="w-full sm:max-w-md mx-auto py-20 flex flex-col justify-center items-center">
        <img src="/images/logo.svg" class="h-20 w-auto" />
        <h1 class="text-center mt- text-center text-3xl font-bold tracking-tight text-black">
            Rent a Car Biao
        </h1>
        <h2 class="text-center mt- text-center text-2xl font-bold tracking-tight text-black">
            登録
        </h2>
        <form asp-action="Register" asp-controller="Auth" method="post" class="mt-8 flex flex-col py-8 px-4 sm:px-10 bg-white sm:mx-auto sm:w-full sm:max-w-md shadow-lg rounded-md">
            <div>
                <label asp-for="LoginId" class="block font-medium text-sm text-gray-700"></label>
                <div class="mt-1">
                    <input asp-for="LoginId" type="text" class="w-full px-4 py-2 border rounded-md dark:bg-darker dark:border-gray-700 focus:outline-none focus:ring focus:ring-primary-100 dark:focus:ring-primary-darker w-full" />
                </div>
                <div class="mt-1 text-red-500 text-sm">
                    @Html.ValidationMessageFor(m => m.LoginId)
                </div>
            </div>
            <div class="mt-6">
                <label asp-for="Name" class="block font-medium text-sm text-gray-700"></label>
                <div class="mt-1">
                    <input asp-for="Name" type="text" class="w-full px-4 py-2 border rounded-md dark:bg-darker dark:border-gray-700 focus:outline-none focus:ring focus:ring-primary-100 dark:focus:ring-primary-darker w-full" />
                </div>
                <div class="mt-1 text-red-500 text-sm">
                    @Html.ValidationMessageFor(m => m.Name)
                </div>
            </div>
            <div class="mt-6">
                <label asp-for="Password" class="block font-medium text-sm text-gray-700"></label>
                <div class="mt-1">
                    <input asp-for="Password" type="password" autocomplete="current-password" class="w-full px-4 py-2 border rounded-md dark:bg-darker dark:border-gray-700 focus:outline-none focus:ring focus:ring-primary-100 dark:focus:ring-primary-darker w-full" />
                </div>
                <div class="mt-1 text-red-500 text-sm">
                    @Html.ValidationMessageFor(m => m.Password)
                </div>
            </div>
            <div class="mt-6">
                <label asp-for="ConfirmPassword" class="block text-sm font-medium text-gray-700"></label>
                <div class="mt-1">
                    <input asp-for="ConfirmPassword" type="password" autocomplete="current-password" class="w-full px-4 py-2 border rounded-md dark:bg-darker dark:border-gray-700 focus:outline-none focus:ring focus:ring-primary-100 dark:focus:ring-primary-darker w-full" />
                </div>
                <div class="mt-1 text-red-300 text-sm">
                    @Html.ValidationMessageFor(m => m.ConfirmPassword)
                </div>
            </div>
            <div class="mt-6 flex justify-end items-center">
                <a asp-action="Login" asp-controller="Auth" class="underline text-sm text-gray-600 hover:text-gray-900 rounded-md focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                    ログイン画面
                </a>
                <button type="submit" class="inline-flex items-center px-4 py-2 text-sm text-white rounded-md bg-primary hover:bg-primary-dark focus:outline-none focus:ring focus:ring-primary-dark focus:ring-offset-1 focus:ring-offset-white dark:focus:ring-offset-dark ml-3">
                    登録
                </button>
            </div>
        </form>
    </section>
</div>
